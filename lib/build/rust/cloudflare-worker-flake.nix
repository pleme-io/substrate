# ============================================================================
# CLOUDFLARE-WORKER-FLAKE — zero-boilerplate Cloudflare Worker (worker-rs)
# ============================================================================
#
# Wraps a `crate-type = ["cdylib"]` Rust crate that uses the `worker` crate
# into a flake output that produces a deployable Worker artifact (WASM + JS
# shim generated by worker-build). Mirrors the substrate Leptos flake API.
#
# Usage from a consumer flake.nix:
#   outputs = { self, nixpkgs, substrate, fenix, ... }:
#     (import "${substrate}/lib/build/rust/cloudflare-worker-flake.nix" {
#       inherit nixpkgs substrate;
#     }) {
#       inherit self;
#       name = "my-webhook";
#       cratePath = "crates/my-webhook";     # workspace member containing src/lib.rs
#       wranglerConfig = "crates/my-webhook/wrangler.toml";
#     };
#
# Produces:
#   packages.default       = worker-build output (dist/), ready for `wrangler deploy`
#   apps.build             = `worker-build --release`
#   apps.deploy            = `wrangler deploy --config <wranglerConfig>`
#   apps.dev               = `wrangler dev --local`
#   devShells.default      = fenix + wrangler + worker-build
{
  nixpkgs,
  substrate ? null,
  fenix ? null,
  ...
}:
{
  self,
  name,
  cratePath,
  wranglerConfig ? "${cratePath}/wrangler.toml",
  systems ? [ "aarch64-darwin" "x86_64-linux" "aarch64-linux" ],
  ...
}:
let
  flakeWrapper = import ../../util/flake-wrapper.nix { inherit nixpkgs; };

  resolveFenix = system:
    if fenix != null then fenix.packages.${system}
    else if self ? inputs && self.inputs ? fenix then self.inputs.fenix.packages.${system}
    else throw "cloudflare-worker-flake: fenix input required";

  mkPerSystem = system: let
    pkgs = import nixpkgs { inherit system; };
    fenixPkgs = resolveFenix system;
    rustToolchain = fenixPkgs.combine [
      fenixPkgs.latest.cargo
      fenixPkgs.latest.rustc
      fenixPkgs.targets.wasm32-unknown-unknown.latest.rust-std
    ];
    devTools = [
      rustToolchain
      pkgs.pkg-config
      pkgs.openssl
      pkgs.wasm-bindgen-cli
      pkgs.binaryen
      pkgs.nodejs_20
      pkgs.nodePackages.wrangler
    ];
    binPath = pkgs.lib.makeBinPath devTools;

    mkScriptApp = script: {
      type = "app";
      program = "${pkgs.writeShellScriptBin "${name}-app" ''
        set -euo pipefail
        export PATH=${binPath}:$PATH
        ${script}
      ''}/bin/${name}-app";
    };

    # worker-build cannot currently run in a sealed Nix sandbox (it installs
    # itself via cargo install on first run). The returned package is a
    # convenience stub; actual builds happen via `nix run .#build` in the
    # dev shell, matching how substrate's leptos-build does it.
    workerStub = pkgs.runCommand "${name}-worker-stub" {} ''
      mkdir -p $out
      echo "Run \`nix run .#build\` to produce the actual Worker artifact." > $out/README
    '';
  in {
    packages.default = workerStub;
    apps = {
      build = mkScriptApp ''
        cd ${cratePath}
        if ! command -v worker-build >/dev/null 2>&1; then
          cargo install -q --locked worker-build
        fi
        worker-build --release
      '';
      deploy = mkScriptApp ''
        wrangler deploy --config ${wranglerConfig} "$@"
      '';
      dev = mkScriptApp ''
        cd ${cratePath}
        wrangler dev --config wrangler.toml --local "$@"
      '';
      secret-put = mkScriptApp ''
        [[ $# -ge 1 ]] || { echo "usage: nix run .#secret-put -- <SECRET_NAME>"; exit 1; }
        wrangler secret put "$1" --config ${wranglerConfig}
      '';
    };
    devShells.default = pkgs.mkShellNoCC {
      buildInputs = devTools;
      shellHook = ''
        echo "${name} Cloudflare Worker — dev shell"
        echo "  nix run .#build     # compile to wasm + shim"
        echo "  nix run .#deploy    # wrangler deploy"
        echo "  nix run .#dev       # local dev server"
      '';
    };
  };
in
  flakeWrapper.mkFlakeOutputs { inherit systems mkPerSystem; }
