# dispatcher-coverage-test.nix — typed coverage assertion. Enforces
# the substrate-wide "common language" invariant: every variant
# kind a typed Rust enum emits (per `dispatcher-catalog.json`,
# generated by `gen dispatchers`) MUST have a matching helpers
# arm in the matching `substrate/lib/build/<ecosystem>/quirk-apply.nix`.
#
# Drift between an adapter's Rust enum and its Nix dispatch table
# becomes a CI failure here — exactly the bug class typed-spec
# contracts exist to prevent.
#
# Refresh the catalog after any adapter enum gains/loses a variant:
#   cd ~/code/github/pleme-io/gen
#   cargo run --release -p gen-cli -- --format json dispatchers \
#     > ~/code/github/pleme-io/substrate/lib/build/shared/dispatcher-catalog.json
#
# Usage:
#   nix-instantiate --eval --strict --json -E \
#     'import ./substrate/lib/build/shared/dispatcher-coverage-test.nix {}'
{ lib ? (import <nixpkgs> {}).lib }:
let
  catalog = builtins.fromJSON (builtins.readFile ./dispatcher-catalog.json);

  assertEq = name: expected: actual:
    if expected == actual then "✓ ${name}"
    else throw "✗ ${name}: expected ${builtins.toJSON expected}, got ${builtins.toJSON actual}";

  # Map adapter ecosystem name → substrate build subdir name. The
  # cargo adapter lives at `substrate/lib/build/rust/` (the dir
  # predates the gen adapter naming); future entries land when an
  # adapter name diverges from its substrate dir name.
  ecoToDir = {
    cargo = "rust";
  };
  resolveDir = name: ecoToDir.${name} or name;

  # Load each ecosystem's quirk-apply.nix to introspect its helpers
  # table. The shared mk-typed-dispatcher returns
  # `{ applyVariants; applyQuirks; }` — we don't see the helpers
  # directly, but we can verify coverage by *probing*: pass each
  # known kind through applyQuirks and assert it doesn't throw
  # (the unknown-kind throw is the failure signal).
  loadEco = name: import (../. + "/${resolveDir name}/quirk-apply.nix") { inherit lib; };

  # Build a minimal probe variant for a given kind + field list.
  # Each field gets a placeholder string so the helpers arm can
  # dereference whatever it expects.
  probeFor = kind: fields:
    builtins.listToAttrs (
      [{ name = "kind"; value = kind; }] ++
      (map (f: { name = f; value = if f == "fields" then [] else "probe"; }) fields)
    );

  # Per-ecosystem coverage: every reflected variant kind must not
  # throw when threaded through applyQuirks.
  coverEco = entry:
    let
      eco = loadEco entry.ecosystem;
      probe = variant:
        let
          v = probeFor variant.kind variant.fields;
          r = builtins.tryEval (eco.applyQuirks [ v ] {});
        in
          if r.success then
            "✓ ${entry.ecosystem}: kind '${variant.kind}' has a helpers arm"
          else
            throw "✗ ${entry.ecosystem}: kind '${variant.kind}' has no helpers arm in substrate/lib/build/${entry.ecosystem}/quirk-apply.nix (drifted from gen-${entry.ecosystem}/src/quirks.rs)";
    in map probe entry.variants;

  # Sanity: variant_count agrees with variants.len fleet-wide.
  variantCountAgrees = entry:
    assertEq
      "${entry.ecosystem}: variant_count matches variants list length"
      entry.variant_count
      (builtins.length entry.variants);

  ecosystemCount = builtins.length catalog;
  ecoCountTest = assertEq "catalog has 9 ecosystems" 9 ecosystemCount;

  countTests = map variantCountAgrees catalog;
  coverageTests = lib.lists.flatten (map coverEco catalog);
in
[ ecoCountTest ] ++ countTests ++ coverageTests
