# mkBuildSpec (Go) — derive Go.build-spec.json via gen, IFD fallback.
#
# Substrate's gen-driven Go build path — the Go analogue of
# substrate/lib/build/rust/mk-build-spec.nix. The consumer's repository
# commits `Go.build-spec.json` + `Go.gen.lock` (regenerated by gen CI on every
# go.mod / go.sum change) and substrate **prefers the committed artifact** — no
# IFD, near-instant evaluation, cache-friendly across hosts. When the committed
# spec is missing, substrate falls back to IFD (Import-From-Derivation):
# `gen build .` inside a `__noChroot` nix sandbox (cargo/go metadata + the
# vendorHash prefetch need network), and the resulting JSON is consumed
# transparently.
#
# ## Why this primitive
#
# Pure IFD is correct but slow: every consumer rebuild blocks eval on a
# `gen build` sandbox, IFD is disabled in many CI contexts, and the vendorHash
# prefetch needs network (`__noChroot`). The committed-spec fast path makes the
# steady state IFD-free; this file is only reached when no committed spec
# exists. The delta path (lockfile-delta.nix) is preferred above BOTH and is
# IFD-free even on the first build for delta-carrying repos.
#
# ## Inputs
#
# - `hostPkgs` — explicit because pkgsStatic's `.buildPackages` is itself, not
#                the darwin/linux host. The IFD always runs on the build
#                machine.
# - `gen`      — substrate-bound gen package. When null, resolved from the
#                committed `gen-pin.json` via `builtins.getFlake` (mirrors the
#                rust path's self-heal). NOTE: Go support requires gen's
#                gomod-parity branch to be merged + published — the pinned rev
#                must carry the gomod adapter.
# - `src`      — consumer's Go module root (path).
#
# ## Output
#
# A derivation whose output `$out/Go.build-spec.json` is the typed build-spec
# ready to feed into the Go lockfile-builder. Substrate's wrappers do this
# transparently — consumers never see the IFD machinery.
{
  hostPkgs,
  gen ? null,
  src,
}:

let
  # Resolve gen from the committed pin when the caller didn't pass one — same
  # self-heal as the rust mk-build-spec / lockfile-builder. The pin lives next
  # to this file and is the single source of truth for the Go-side gen rev.
  # This IFD-time `getFlake` against the locked rev does NOT grow any lock.
  resolvedGen =
    if gen != null then gen
    else
      let
        genPin = builtins.fromJSON (builtins.readFile ./gen-pin.json);
        autoGenFlake = builtins.getFlake "github:pleme-io/gen/${genPin.rev}";
        sys = hostPkgs.stdenv.hostPlatform.system;
      in
        autoGenFlake.packages.${sys}.host-tool
          or autoGenFlake.packages.${sys}.default;

  committedSpecPath = src + "/Go.build-spec.json";
  hasCommittedSpec = builtins.pathExists committedSpecPath;

  # ── Fast path: committed spec exists ────────────────────────────
  committedDerivation = hostPkgs.runCommand "go-build-spec-committed" {
    passthru.source = "committed";
  } ''
    mkdir -p $out
    cp ${committedSpecPath} $out/Go.build-spec.json
  '';

  # ── Fallback: IFD ────────────────────────────────────────────────
  # `gen build .` auto-detects the go.mod and emits Go.build-spec.json +
  # Go.gen.lock. The vendorHash prefetch shells out to `go mod vendor` /
  # nix-prefetch against the module proxy — needs network, hence __noChroot.
  ifdDerivation = hostPkgs.runCommand "go-build-spec-ifd" {
    nativeBuildInputs = [
      resolvedGen
      hostPkgs.go
      hostPkgs.cacert
      hostPkgs.git
    ];
    SSL_CERT_FILE = "${hostPkgs.cacert}/etc/ssl/certs/ca-bundle.crt";
    NIX_SSL_CERT_FILE = "${hostPkgs.cacert}/etc/ssl/certs/ca-bundle.crt";
    __noChroot = true;
    src = src;
    passthru.source = "ifd";
  } ''
    cp -r $src/* .
    chmod -R u+w .
    mkdir -p $out
    export GOPATH=$PWD/.go
    export GOCACHE=$PWD/.gocache
    export HOME=$PWD
    gen build . > /dev/null
    if [ ! -f Go.build-spec.json ]; then
      echo "mkBuildSpec(go): gen build did not produce Go.build-spec.json" >&2
      exit 1
    fi
    cp Go.build-spec.json $out/
  '';

  # ── Deterministic-performance visibility ─────────────────────────
  # IFD runs `gen build .` (network, __noChroot) DURING EVAL — variable
  # latency, not shared across hosts. Falling to IFD was SILENT, so the
  # eval-time tax was invisible. Emit a loud trace naming the source so every
  # IFD repo is visible + actionable — commit its `gen build .` output
  # (Go.build-spec.json + Go.gen.lock) to take the deterministic no-IFD path.
  ifdDerivationTraced = builtins.trace
    "mkBuildSpec(go)[IFD]: no committed Go.build-spec.json for ${toString src} → eval-time `gen build` (network). Commit Go.gen.lock for a deterministic no-IFD build."
    ifdDerivation;

in
  if hasCommittedSpec then committedDerivation else ifdDerivationTraced
